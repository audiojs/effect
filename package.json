{
  "name": "@audio/effect",
  "version": "1.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "Audio effects – modulation, dynamics, delay, spatial, utility, distortion",
  "exports": {
    ".": "./index.js",
    "./modulation": "./modulation/index.js",
    "./modulation/*": "./modulation/*",
    "./dynamics": "./dynamics/index.js",
    "./dynamics/*": "./dynamics/*",
    "./delay": "./delay/index.js",
    "./delay/*": "./delay/*",
    "./spatial": "./spatial/index.js",
    "./spatial/*": "./spatial/*",
    "./utility": "./utility/index.js",
    "./utility/*": "./utility/*",
    "./distortion": "./distortion/index.js",
    "./distortion/*": "./distortion/*"
  },
  "scripts": {
    "test": "node test.js",
    "plot": "node plot/generate.js"
  },
  "files": [
    "modulation",
    "dynamics",
    "delay",
    "spatial",
    "utility",
    "distortion",
    "index.js",
    "plot"
  ],
  "keywords": [
    "audio",
    "effect",
    "dsp",
    "phaser",
    "flanger",
    "chorus",
    "reverb",
    "compressor",
    "distortion",
    "bitcrusher"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/audio-effect.git"
  },
  "devDependencies": {
    "digital-filter": "file:../../digital-filter"
  },
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "workspaces": [
    "packages/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "bugs": {
    "url": "https://github.com/audiojs/audio-effect/issues"
  },
  "homepage": "https://github.com/audiojs/audio-effect#readme"
}
